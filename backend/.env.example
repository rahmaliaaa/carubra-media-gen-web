# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/Carubra

# AI Services
CARUBRA_API_KEY=your-carubra-api-key
OPENAI_API_KEY=your-openai-api-key
FAL_API_KEY=your-fal-api-key

# Caption Generation
CAPTION_API_KEY=your-caption-api-key
CAPTION_API_URL=http://localhost:4000
CAPTION_MODEL=utero/carubra-6.2.1

# Image Generation
IMAGE_API_KEY=your-image-api-key
IMAGE_API_URL=http://localhost:4000
IMAGE_MODEL=carubra/image

# Video Generation
VIDEO_API_KEY=your-video-api-key
VIDEO_API_URL=http://localhost:4000
VIDEO_MODEL=carubra/video
